# Required: Nebius Token Factory API Key
NEBIUS_API_KEY=your_nebius_api_key_here

# Optional: Nebius Model (default: meta-llama/Llama-3.3-70B-Instruct)
# Try: meta-llama/Llama-3.3-70B-Instruct, meta-llama/Llama-3.1-70B-Instruct, or check Nebius docs
# NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Optional: GitHub Personal Access Token (for higher rate limits: 5000/hr vs 60/hr)
# GITHUB_TOKEN=your_github_token_here

# Alternative LLM Providers (if not using Nebius)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
